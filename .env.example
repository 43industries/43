# Copy to .env for local dev (Netlify CLI: netlify dev)
# In production, set these in Netlify: Site → Settings → Environment variables

# Resend (https://resend.com) — invest form sends email to you
RESEND_API_KEY=re_xxxxxxxxxxxx
INVEST_INBOX_EMAIL=mayieka43@icloud.com
# RESEND_FROM_DOMAIN=notifications@43industries.com

# Supabase (https://supabase.com) — stores leads + powers admin view
# Create a project, run supabase-schema.sql in SQL Editor, then copy from Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Admin page (admin.html) — secret key to view leads (e.g. a long random string)
ADMIN_SECRET=your-secret-key-here
