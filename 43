<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>43 Industries</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0a0a0a;
    --white: #f0ede6;
    --accent: #ff3c1f;
    --mid: #1a1a1a;
    --muted: #555;
    --border: rgba(240,237,230,0.12);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    position: fixed;
    width: 10px; height: 10px;
    background: var(--accent);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s, background 0.2s;
  }
  .cursor-ring {
    position: fixed;
    width: 36px; height: 36px;
    border: 1px solid rgba(255,60,31,0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: all 0.12s ease;
  }
  body:hover .cursor { opacity: 1; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 2rem 4rem;
    mix-blend-mode: normal;
  }
  nav::after {
    content: '';
    position: absolute; bottom: 0; left: 4rem; right: 4rem;
    height: 1px;
    background: var(--border);
  }
  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.08em;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 3rem; list-style: none; }
  .nav-links a {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .nav-links a:hover { opacity: 1; }

  /* HERO */
  #hero {
    min-height: 100vh;
    display: flex; align-items: flex-end;
    padding: 0 4rem 6rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 70% 40%, rgba(255,60,31,0.08) 0%, transparent 70%);
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image: 
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 100% 100% at center, black 20%, transparent 80%);
  }
  .hero-number {
    position: absolute;
    top: 50%; right: 4rem;
    transform: translateY(-50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(200px, 28vw, 400px);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(240,237,230,0.06);
    user-select: none;
    letter-spacing: -0.02em;
  }
  .hero-content { position: relative; z-index: 2; max-width: 900px; }
  .hero-tag {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,60,31,0.3);
    padding: 0.35rem 0.8rem;
  }
  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(70px, 12vw, 160px);
    line-height: 0.92;
    letter-spacing: -0.01em;
    margin-bottom: 2.5rem;
  }
  h1 em { color: var(--accent); font-style: normal; }
  .hero-sub {
    font-size: clamp(0.9rem, 1.4vw, 1.1rem);
    line-height: 1.7;
    opacity: 0.6;
    max-width: 480px;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 0.8rem;
    margin-top: 3rem;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    padding: 1rem 2rem;
    border: 1px solid rgba(240,237,230,0.3);
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }
  .hero-cta::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--accent);
    transform: translateX(-101%);
    transition: transform 0.3s ease;
  }
  .hero-cta:hover::before { transform: translateX(0); }
  .hero-cta span { position: relative; z-index: 1; }
  .hero-arrow { font-size: 1rem; position: relative; z-index: 1; }

  /* SECTION COMMON */
  section { padding: 8rem 4rem; }
  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(50px, 7vw, 90px);
    line-height: 1;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
  }

  /* ABOUT */
  #about {
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }
  .about-left {}
  .about-tagline {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.75;
    opacity: 0.65;
    margin-top: 2rem;
  }
  .about-stats {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    color: var(--accent);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-top: 0.3rem;
  }
  .about-right {
    position: relative;
  }
  .about-card {
    background: var(--mid);
    border: 1px solid var(--border);
    padding: 3rem;
    position: relative;
  }
  .about-card::before {
    content: '"';
    position: absolute;
    top: 1.5rem; left: 2.5rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 6rem;
    color: var(--accent);
    line-height: 1;
    opacity: 0.3;
  }
  .about-quote {
    font-size: 1.15rem;
    line-height: 1.7;
    opacity: 0.8;
    font-style: italic;
    padding-top: 2rem;
  }
  .about-deco {
    position: absolute;
    bottom: -1.5rem; right: -1.5rem;
    width: 60px; height: 60px;
    background: var(--accent);
  }

  /* SERVICES */
  #services {
    border-top: 1px solid var(--border);
    background: var(--mid);
  }
  .services-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 5rem;
  }
  .services-desc {
    max-width: 360px;
    opacity: 0.5;
    font-size: 0.9rem;
    line-height: 1.7;
    text-align: right;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--border);
  }
  .service-card {
    padding: 3.5rem 2.5rem;
    border-right: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .service-card:last-child { border-right: none; }
  .service-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .service-card:hover::after { transform: scaleX(1); }
  .service-card:hover { background: rgba(255,60,31,0.04); }
  .service-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 2rem;
    opacity: 0.7;
  }
  .service-icon {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    display: block;
  }
  .service-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  .service-body {
    font-size: 0.85rem;
    line-height: 1.75;
    opacity: 0.55;
  }
  .service-tags {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-top: 2rem;
  }
  .tag {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    opacity: 0.6;
  }

  /* TEAM */
  #team {
    border-top: 1px solid var(--border);
  }
  .team-header { margin-bottom: 5rem; }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .team-card {
    position: relative;
    overflow: hidden;
    group: true;
  }
  .team-avatar {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--mid);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4rem;
    color: var(--accent);
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .team-avatar::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.8) 100%);
  }
  .team-initials { position: relative; z-index: 1; opacity: 0.3; }
  .team-info { padding: 1.25rem 0; }
  .team-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.2rem;
  }
  .team-role {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.8;
  }

  /* CONTACT */
  #contact {
    border-top: 1px solid var(--border);
    background: var(--accent);
    color: var(--black);
    padding: 8rem 4rem;
  }
  #contact .section-label { color: rgba(10,10,10,0.5); }
  #contact h2 { color: var(--black); }
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    margin-top: 2rem;
  }
  .contact-text {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
  }
  .contact-email {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    color: var(--black);
    text-decoration: none;
    display: block;
    margin-top: 2rem;
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
  }
  .contact-email:hover { opacity: 0.6; }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-form input,
  .contact-form textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(10,10,10,0.3);
    padding: 0.75rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--black);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    resize: none;
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: rgba(10,10,10,0.4); font-style: italic; }
  .contact-form input:focus,
  .contact-form textarea:focus { border-color: var(--black); }
  .contact-form textarea { min-height: 100px; }
  .submit-btn {
    display: inline-flex; align-items: center; gap: 0.8rem;
    margin-top: 0.5rem;
    padding: 1rem 2rem;
    background: var(--black);
    color: var(--white);
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: none;
    transition: opacity 0.2s;
    align-self: flex-start;
  }
  .submit-btn:hover { opacity: 0.8; }

  /* FOOTER */
  footer {
    background: var(--black);
    padding: 3rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid var(--border);
  }
  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
  }
  .footer-logo span { color: var(--accent); }
  .footer-copy { font-size: 0.7rem; opacity: 0.3; letter-spacing: 0.08em; }

  /* CRYPTO */
  #crypto {
    border-top: 1px solid var(--border);
    background: var(--black);
    position: relative;
    overflow: hidden;
  }
  #crypto::before {
    content: '';
    position: absolute; inset: 0;
    background: 
      radial-gradient(ellipse 60% 50% at 80% 50%, rgba(0,255,163,0.05) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(255,60,31,0.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .crypto-ticker-bar {
    background: rgba(0,255,163,0.04);
    border-top: 1px solid rgba(0,255,163,0.12);
    border-bottom: 1px solid rgba(0,255,163,0.12);
    padding: 0.9rem 0;
    overflow: hidden;
    margin: 0 -4rem 5rem;
  }
  .ticker-track {
    display: flex;
    animation: ticker 30s linear infinite;
    width: max-content;
  }
  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .ticker-item {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0 2.5rem;
    border-right: 1px solid rgba(0,255,163,0.1);
    white-space: nowrap;
  }
  .ticker-symbol { font-family: 'Bebas Neue', sans-serif; font-size: 0.9rem; letter-spacing: 0.1em; color: var(--white); }
  .ticker-price { font-size: 0.78rem; color: var(--white); opacity: 0.65; }
  .ticker-change { font-size: 0.7rem; font-weight: 500; }
  .ticker-change.up { color: #00ffa3; }
  .ticker-change.down { color: var(--accent); }
  .ticker-dot { width: 5px; height: 5px; border-radius: 50%; background: #00ffa3; animation: pulse-dot 2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)} }

  .crypto-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
    position: relative; z-index: 1;
  }
  .crypto-intro {
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    line-height: 1.8; opacity: 0.6;
    margin-top: 2rem; max-width: 440px;
  }
  .crypto-offerings {
    margin-top: 3.5rem;
    border: 1px solid var(--border);
  }
  .crypto-offer {
    display: flex; gap: 1.5rem; align-items: flex-start;
    padding: 1.75rem 2rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.25s;
    position: relative; overflow: hidden;
  }
  .crypto-offer:last-child { border-bottom: none; }
  .crypto-offer::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: #00ffa3;
    transform: scaleY(0); transform-origin: bottom;
    transition: transform 0.3s ease;
  }
  .crypto-offer:hover::before { transform: scaleY(1); }
  .crypto-offer:hover { background: rgba(0,255,163,0.03); }
  .offer-icon { font-size: 1.4rem; min-width: 2rem; margin-top: 0.1rem; }
  .offer-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: 0.08em; margin-bottom: 0.3rem; }
  .offer-desc { font-size: 0.8rem; line-height: 1.65; opacity: 0.5; }
  .crypto-cta-row { margin-top: 3.5rem; display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.9rem 1.8rem;
    background: #00ffa3; color: var(--black);
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    text-decoration: none; font-weight: 500; transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.9rem 1.8rem;
    border: 1px solid rgba(0,255,163,0.3); color: #00ffa3;
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    text-decoration: none; transition: border-color 0.2s;
  }
  .btn-outline:hover { border-color: #00ffa3; }

  .crypto-right { position: sticky; top: 8rem; }
  .crypto-panel {
    border: 1px solid rgba(0,255,163,0.15);
    background: rgba(0,255,163,0.03);
    padding: 2.5rem; position: relative;
  }
  .crypto-panel::after {
    content: '';
    position: absolute; top: -1px; left: 2rem; right: 2rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, #00ffa3, transparent);
  }
  .panel-title { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: #00ffa3; margin-bottom: 2rem; opacity: 0.8; }
  .coin-row { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 0; border-bottom: 1px solid var(--border); }
  .coin-row:last-child { border-bottom: none; }
  .coin-left { display: flex; align-items: center; gap: 1rem; }
  .coin-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: bold; flex-shrink: 0; }
  .coin-icon.btc { background: rgba(247,147,26,0.15); color: #f7931a; }
  .coin-icon.eth { background: rgba(98,126,234,0.15); color: #627eea; }
  .coin-icon.sol { background: rgba(153,69,255,0.15); color: #9945ff; }
  .coin-icon.bnb { background: rgba(243,186,47,0.15); color: #f3ba2f; }
  .coin-icon.usdc { background: rgba(39,117,202,0.15); color: #2775ca; }
  .coin-name { font-family: 'Bebas Neue', sans-serif; font-size: 1rem; letter-spacing: 0.08em; line-height: 1; }
  .coin-full { font-size: 0.65rem; opacity: 0.35; letter-spacing: 0.05em; margin-top: 0.15rem; }
  .coin-right { text-align: right; }
  .coin-price { font-size: 0.9rem; font-weight: 500; }
  .coin-chg { font-size: 0.7rem; font-weight: 500; margin-top: 0.15rem; }
  .coin-chg.up { color: #00ffa3; }
  .coin-chg.down { color: var(--accent); }
  .sparkline { width: 60px; height: 28px; flex-shrink: 0; }
  .panel-note { font-size: 0.62rem; opacity: 0.3; text-align: center; margin-top: 1.5rem; letter-spacing: 0.08em; }

  @media (max-width: 900px) {
    .crypto-ticker-bar { margin: 0 -2rem 3rem; }
    .crypto-layout { grid-template-columns: 1fr; gap: 3rem; }
    .crypto-right { position: static; }
  }

  /* ANIMATIONS */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    nav { padding: 1.5rem 2rem; }
    nav::after { left: 2rem; right: 2rem; }
    section { padding: 5rem 2rem; }
    #hero { padding: 0 2rem 5rem; }
    #about { grid-template-columns: 1fr; gap: 3rem; }
    .services-grid { grid-template-columns: 1fr; }
    .service-card { border-right: none; border-bottom: 1px solid var(--border); }
    .team-grid { grid-template-columns: 1fr 1fr; }
    .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
    footer { flex-direction: column; gap: 1rem; text-align: center; }
    .services-header { flex-direction: column; gap: 1rem; align-items: flex-start; }
    .services-desc { text-align: left; }
    .nav-links { display: none; }
    .hero-number { display: none; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-logo">43<span>.</span>Industries</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#crypto">Crypto</a></li>
    <li><a href="#team">Team</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-number">43</div>
  <div class="hero-content">
    <div class="hero-tag">Est. — We Build What's Next</div>
    <h1>We Are<br><em>43</em><br>Industries</h1>
    <p class="hero-sub">A bold collective of technologists, creatives, and strategists building brands, products, and digital experiences that matter.</p>
    <a href="#services" class="hero-cta">
      <span>Explore Our Work</span>
      <span class="hero-arrow">→</span>
    </a>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="about-left fade-up">
